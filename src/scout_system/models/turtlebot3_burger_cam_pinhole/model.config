<?xml version="1.0"?>
<model>
  <name>turtlebot3_burger_cam_pinhole</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>Scout System</name>
  </author>

  <description>
    TurtleBot3 burger with a *normal pinhole* camera (62.2 deg HFOV,
    matching the actual Raspberry Pi camera v2 used on the real robot).
    Replaces the upstream burger_cam which uses a 182 deg wide-angle
    fisheye projection that breaks pinhole-based perception
    (CameraInfo K matrix is unrepresentable for a 182 deg FOV, so the
    plugin publishes garbage intrinsics like fx=fy=-3.3 which makes
    every atan2(u-cx, fx) bearing computation meaningless).
  </description>
</model>
